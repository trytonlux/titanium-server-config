[Unit]
Description=Homer Dashboard

[Container]
Label=io.containers.autoupdate=registry
Image=docker.io/b4bz/homer:latest
PublishPort=8095:8080

HealthCmd=wget --no-verbose --tries=1 --spider http://127.0.0.1:8080 || exit 1
Notify=healthy

Volume=/storage/containers/homer/config.yaml:/www/assets/config.yml

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
