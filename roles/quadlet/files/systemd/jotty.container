[Unit]
Description=Jotty Notes and Todos

[Container]
Label=io.containers.autoupdate=registry
Image=ghcr.io/fccview/jotty:latest
PublishPort=6464:3000

Volume=/storage/containers/jotty/data:/app/data:U
Volume=/storage/containers/jotty/config:/app/config:U
Volume=/storage/containers/jotty/cache:/app/.next/cache:U

Environment=NODE_ENV=production
Environment=HTTPS=true
Environment=APP_URL=https://notes.titanium-server.thelux.family
Environment=INTERNAL_API_URL=http://localhost:3000

HealthCmd=wget --spider --tries=1 http://0.0.0.0:3000/api/health || exit 1
Notify=healthy

User=1000

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
